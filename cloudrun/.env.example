# Cloud Hosting environment variables. Do not place real secrets in this file.
PORT=8080
TCB_ENV=your-cloudbase-environment-id
HAIGOO_API_ORIGIN=https://haigooremote.com
MINI_GATEWAY_SHARED_SECRET=replace-with-a-32-byte-random-secret
MINI_SESSION_SECRET=replace-with-a-different-32-byte-random-secret
WECHAT_MINI_APP_ID=wx...
WECHAT_MINI_APP_SECRET=...
MINI_SYNC_SECRET=replace-with-a-third-random-secret
# Optional performance tuning. Defaults are designed to keep callContainer fast.
MINI_SYNC_PAGES_PER_RUN=3
MINI_SYNC_WRITE_CONCURRENCY=8
MINI_LOGO_CONCURRENCY=2
# Reject unusually large or malformed remote logo responses before they can
# exhaust the cloud-hosting Node process. Value is in bytes.
MINI_LOGO_MAX_BYTES=2097152
