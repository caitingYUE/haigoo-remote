{
  "functions": {
    "api/*": {
      "maxDuration": 300
    }
  },
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/pic_lists/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-enrich",
      "schedule": "50 1 * * *"
    },
    {
      "path": "/api/cron/rotate-featured",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/stream-verify-links",
      "schedule": "10 4 * * *"
    },
    {
      "path": "/api/cron/membership-lifecycle",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cleanup-analytics",
      "schedule": "20 2 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/:task",
      "destination": "/api/cron/index?task=:task"
    },
    {
      "source": "/api/stream-translate-jobs",
      "destination": "/api/cron/index?task=stream-translate-jobs"
    },
    {
      "source": "/api/data/:path*",
      "destination": "/api/data?resource=:path*"
    },
    {
      "source": "/api/user-profile",
      "destination": "/api/users"
    },
    {
      "source": "/api/check-user-data",
      "destination": "/api/admin-ops?action=check-user"
    },
    {
      "source": "/api/diagnose-db",
      "destination": "/api/admin-ops?action=diagnose"
    },
    {
      "source": "/api/run-migration",
      "destination": "/api/admin-ops?action=migrate"
    },
    {
      "source": "/api/applications",
      "destination": "/api/users?resource=applications"
    },
    {
      "source": "/api/resumes",
      "destination": "/api/users?resource=resumes"
    },
    {
      "source": "/api/job-matching",
      "destination": "/api/users?resource=job-matching"
    },
    {
      "source": "/api/parse-resume-new",
      "destination": "/api/users?resource=resumes"
    },
    {
      "source": "/api/stats",
      "destination": "/api/data?resource=stats"
    },
    {
      "source": "/dream_land_demo",
      "destination": "/dream_land_demo/index.html"
    },
    {
      "source": "/dream_land_demo/:path*",
      "destination": "/dream_land_demo/:path*"
    },
    {
      "source": "/api/:match*",
      "destination": "/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
